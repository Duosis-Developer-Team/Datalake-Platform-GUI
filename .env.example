# Datalake Platform GUI — example environment (single file for Compose + APIs + Dash)
# Copy to ".env" and adjust:  cp .env.example .env

# ==============================================================================
# PostgreSQL — metrics/inventory database (required by datacenter/customer/query APIs)
# ==============================================================================
# Docker Compose loads this via env_file. From inside containers use a host reachable
# from the container (not "localhost" for a DB on the host; use host.docker.internal or LAN IP).
DB_HOST=your-db-host
DB_PORT=5000
DB_NAME=bulutlake
DB_USER=datalakeui
DB_PASS=changeme

# customer-api only: per-statement timeout in milliseconds (0 = disabled).
# DB_STATEMENT_TIMEOUT_MS=0

# Optional: external SLA API (leave empty to disable SLA fetches)
# SLA_API_KEY=

# ==============================================================================
# Docker Compose — microservice profile (Redis + APIs + Dash; external DB above)
# ==============================================================================
# Uncomment to activate the microservice profile by default (see docker-compose.yml):
# COMPOSE_PROFILES=microservice
#
# When the Dash app runs inside Compose, it calls APIs by service name (same network).
# Compose sets defaults; override only if needed:
# DATACENTER_API_URL=http://datacenter-api:8000
# CUSTOMER_API_URL=http://customer-api:8000
# QUERY_API_URL=http://query-api:8000
# ADMIN_API_URL=http://admin-api:8000

# Local dev (APIs on host): use localhost ports matching your setup
DATACENTER_API_URL=http://localhost:8000
CUSTOMER_API_URL=http://localhost:8001
QUERY_API_URL=http://localhost:8002
ADMIN_API_URL=http://localhost:8060

# Optional: revision label for the Dash container (build + runtime). Shown bottom-right in the UI.
# Example: export APP_BUILD_ID=$(git rev-parse --short HEAD) before docker compose build app
APP_BUILD_ID=local

# ==============================================================================
# Optional: local PostgreSQL in Docker (profile "with-db" only — not microservice)
# ==============================================================================
# If you run: docker compose --profile with-db up -d
# then point APIs at the Compose db service:
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=bulutlake
# DB_USER=datalakeui
# DB_PASS=change_me

# ==============================================================================
# Auth database (dedicated PostgreSQL) + Flask session + IAM
# ==============================================================================
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5433
AUTH_DB_NAME=bulutauth
AUTH_DB_USER=authadmin
AUTH_DB_PASS=change_me_auth

# Flask session signing (required in production)
SECRET_KEY=change_me_to_a_long_random_string

# Default bootstrap admin (seeded once)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin123!

# Fernet-compatible secret for LDAP password encryption at rest (optional; falls back to SECRET_KEY)
FERNET_KEY=

# Session lifetime (hours)
SESSION_TTL_HOURS=24

# Set to true to bypass LDAP/session gate (development only; still uses admin user if present)
AUTH_DISABLED=false

# Microservice JWT (defaults to SECRET_KEY; must match API services)
API_JWT_SECRET=
# Require Authorization: Bearer on FastAPI /api/v1 (set true in production with gateway)
API_AUTH_REQUIRED=false

# Optional Redis for permission map cache (same Redis as infra is fine)
REDIS_URL=
PERMISSION_MAP_CACHE_TTL_SEC=300

# ==============================================================================
# AuraNotify (Dash — Availability tabs; X-API-Key header)
# ==============================================================================
# AURANOTIFY_BASE_URL=http://10.0.0.1:5001
# AURANOTIFY_API_KEY=
# ANOTIFY_API_KEY=

# ==============================================================================
# Optional: OpenTelemetry — external Collector (OTLP gRPC). See docs/OTEL_COLLECTOR.md
# ==============================================================================
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector-host:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
