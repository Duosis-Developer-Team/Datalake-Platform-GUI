# Datalake Platform GUI — example environment (single file for Compose + APIs + Dash)
# Copy to ".env" and adjust:  cp .env.example .env

# ==============================================================================
# PostgreSQL — metrics/inventory database (required by datacenter/customer/query APIs)
# ==============================================================================
# Docker Compose loads this via env_file. From inside containers use a host reachable
# from the container (not "localhost" for a DB on the host; use host.docker.internal or LAN IP).
DB_HOST=your-db-host
DB_PORT=5000
DB_NAME=bulutlake
DB_USER=datalakeui
DB_PASS=changeme

# customer-api only: per-statement timeout in milliseconds (0 = disabled).
# DB_STATEMENT_TIMEOUT_MS=0

# GUI worker AuraNotify warm-up only (comma-separated). Does not limit GET /customers.
# Customer Redis cache tiers are managed by customer-api (VIP 15m hot, mapped non-VIP 6h batch).
# WARMED_CUSTOMERS=Boyner
# MAPPED_BATCH_WARM_INTERVAL_HOURS=6
# MAPPED_CACHE_TTL_SECONDS=21600

# Optional: external SLA API (datacenter-api → AuraNotify; required for /availability-annual)
# SLA_API_KEY=
# SLA_DC_SERVICES_URL=http://10.34.8.154:5001/api/sla/datacenter-services

# ==============================================================================
# Docker Compose — microservice profile (Redis + APIs + Dash; external DB above)
# ==============================================================================
# Uncomment to activate the microservice profile by default (see docker-compose.yml):
# COMPOSE_PROFILES=microservice
#
# When the Dash app runs inside Compose, it calls APIs by service name (same network).
# Compose sets defaults; override only if needed:
# DATACENTER_API_URL=http://datacenter-api:8000
# CUSTOMER_API_URL=http://customer-api:8000
# Temporary aggregate Total Energy kW on Overview/global dashboard (0 = live DB totals).
# STATIC_TOTAL_ENERGY_KW=780
# CRM_ENGINE_URL=http://crm-engine:8000
# QUERY_API_URL=http://query-api:8000
# ADMIN_API_URL=http://admin-api:8000

# Local dev (APIs on host): use localhost ports matching your setup
DATACENTER_API_URL=http://localhost:8000
CUSTOMER_API_URL=http://localhost:8001
# crm-engine container exposes 8070; falls back to CUSTOMER_API_URL when unset.
CRM_ENGINE_URL=http://localhost:8070
QUERY_API_URL=http://localhost:8002
ADMIN_API_URL=http://localhost:8060

# Optional: revision label for the Dash container (build + runtime). Shown bottom-right in the UI.
# Example: export APP_BUILD_ID=$(git rev-parse --short HEAD) before docker compose build app
APP_BUILD_ID=local

# ==============================================================================
# Optional: local PostgreSQL in Docker (profile "with-db" only — not microservice)
# ==============================================================================
# If you run: docker compose --profile with-db up -d
# then point APIs at the Compose db service:
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=bulutlake
# DB_USER=datalakeui
# DB_PASS=change_me

# ==============================================================================
# Auth database (dedicated PostgreSQL) + Flask session + IAM
# ==============================================================================
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5433
AUTH_DB_NAME=bulutauth
AUTH_DB_USER=authadmin
AUTH_DB_PASS=change_me_auth

# Flask session signing (required in production)
SECRET_KEY=change_me_to_a_long_random_string

# Default bootstrap admin (seeded once)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin123!

# Fernet-compatible secret for LDAP password encryption at rest (optional; falls back to SECRET_KEY)
FERNET_KEY=

# Session lifetime (hours)
SESSION_TTL_HOURS=24

# Set to true to bypass LDAP/session gate (development only; still uses admin user if present)
AUTH_DISABLED=false

# Microservice JWT (defaults to SECRET_KEY; must match API services)
API_JWT_SECRET=
# Require Authorization: Bearer on FastAPI /api/v1 (set true in production with gateway)
API_AUTH_REQUIRED=false

# Redis for the shared cross-pod data cache (cache_service) AND the permission
# map cache. Strongly recommended in multi-pod deploys: without it each pod
# keeps its own in-process cache, so hit rate collapses to ~1/pods. Unset =>
# per-process fallback (fine for single-process local dev). Same Redis as infra
# is fine; keys are namespaced (dl:fecache:* / dl:perm_map:*).
REDIS_URL=
PERMISSION_MAP_CACHE_TTL_SEC=300

# ==============================================================================
# AuraNotify (Dash — Availability tabs; X-API-Key header)
# ==============================================================================
# AURANOTIFY_BASE_URL=http://10.0.0.1:5001
# AURANOTIFY_API_KEY=
# ANOTIFY_API_KEY=

# ==============================================================================
# Optional: OpenTelemetry — external Collector (OTLP gRPC). See docs/OTEL_COLLECTOR.md
# ==============================================================================
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-otel-collector-host:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# ==============================================================================
# Chatbot / Bulutistan LLMaaS (chatbot-api service)
# ==============================================================================
# SECURITY: never put the real token in this committed file. For local runs,
# export BULUTISTAN_LLM_API_KEY in your shell, or use a gitignored .env.local.
# (.env is git-tracked in this repo, so it is NOT a safe place for the token.)
BULUTISTAN_LLM_BASE_URL=https://api.bulutistan.ai/v1
BULUTISTAN_LLM_API_KEY=
CHATBOT_MODEL=gpt-oss-120b
CHATBOT_FALLBACK_MODEL=qwen3-next-80b-instruct
CHATBOT_TEMPERATURE=0.2
CHATBOT_MAX_TOKENS=900
CHATBOT_TIMEOUT_SECONDS=120
CHATBOT_REQUEST_TIMEOUT_SECONDS=600
CHATBOT_MAX_RETRIES=2
CHATBOT_LLM_REACT_MODE=true
CHATBOT_MAX_TOOL_CALLS_PER_TURN=150
CHATBOT_MAX_LLM_ROUNDS=150
CHATBOT_MAX_TOOL_ITERATIONS=50
CHATBOT_MAX_TOOL_CALLS_PER_ITERATION=10
# Frontend -> internal chatbot-api (server-side only; browser never calls the LLM)
CHATBOT_API_URL=http://chatbot-api:8000
CHATBOT_CLIENT_TIMEOUT=600
CHATBOT_CUSTOMER_API_TIMEOUT_SECONDS=45
# Read-only DB tools — disabled by default. Enable to answer host-level questions
# the APIs don't expose (e.g. per-host CPU). Set CHATBOT_DB_ENABLED=true (locally
# in the gitignored .env.local). Connection params fall back to the main stack's
# DB_* if CHATBOT_DB_* are unset; set CHATBOT_DB_USER/PASS for a dedicated
# read-only user. SELECT-only, allowlisted query templates, row cap + timeout.
CHATBOT_DB_ENABLED=false
CHATBOT_DB_USER=chatbot_readonly
CHATBOT_DB_PASS=
CHATBOT_DB_MAX_ROWS=50
CHATBOT_DB_STATEMENT_TIMEOUT_MS=10000
# Chat turn audit logs (MongoDB via chatbot-log-api microservice)
# CHATBOT_LOG_API_URL/KEY: chatbot-api (write) + GUI app (admin log viewer read)
CHATBOT_LOG_API_ENABLED=true
CHATBOT_LOG_API_URL=http://chatbot-log-api:8000
CHATBOT_LOG_API_KEY=
CHATBOT_LOG_RETENTION_DAYS=90
CHATBOT_LOG_MONGO_USER=chatbot_log
CHATBOT_LOG_MONGO_PASS=change_me_chatbot_log
