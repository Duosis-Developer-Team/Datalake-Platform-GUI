# --- Datalake Platform GUI / Auth DB (dedicated PostgreSQL) ---
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5433
AUTH_DB_NAME=bulutauth
AUTH_DB_USER=authadmin
AUTH_DB_PASS=change_me_auth

# Flask session signing (required in production)
SECRET_KEY=change_me_to_a_long_random_string

# Default bootstrap admin (seeded once)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin123!

# Fernet-compatible secret for LDAP password encryption at rest (optional; falls back to SECRET_KEY)
FERNET_KEY=

# Session lifetime (hours)
SESSION_TTL_HOURS=24

# Set to true to bypass LDAP/session gate (development only; still uses admin user if present)
AUTH_DISABLED=false

# API URLs (Docker Compose defaults shown)
DATACENTER_API_URL=http://localhost:8000
CUSTOMER_API_URL=http://localhost:8001
QUERY_API_URL=http://localhost:8002

APP_BUILD_ID=local
