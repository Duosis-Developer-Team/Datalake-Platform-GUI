# Application environment
# Copy this file to ".env" and adjust values for your environment.

# ------------------------------------------------------------------------------
# External PostgreSQL database (existing server)
# ------------------------------------------------------------------------------
DB_HOST=10.134.16.6
DB_PORT=5000
DB_NAME=bulutlake
DB_USER=datalakeui
DB_PASS=changeme

# ------------------------------------------------------------------------------
# Docker Compose — full microservice stack (PostgreSQL + Redis + 3 APIs + Dash)
# ------------------------------------------------------------------------------
# Uncomment to activate the microservice profile by default (see docker-compose.yml):
# COMPOSE_PROFILES=microservice
#
# When the Dash app runs inside Compose, it calls APIs by service name (same network).
# You can override these if needed:
# DATACENTER_API_URL=http://datacenter-api:8000
# CUSTOMER_API_URL=http://customer-api:8000
# QUERY_API_URL=http://query-api:8000
#
# Compose PostgreSQL service ("db") — align API containers with the same credentials:
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=bulutlake
# DB_USER=datalakeui
# DB_PASS=change_me

