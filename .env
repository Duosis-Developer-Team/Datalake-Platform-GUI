# ─────────────────────────────────────────────────────────────
#  Datalake-GUI — Environment Variables
#  UYARI: Bu dosyayı asla commit etme / paylaşma.
#  Gerçek değerleri buraya gir; placeholder'ları boş bırakma.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (Grafana-backed external DB) ───────────────────
DB_HOST=10.134.16.6
DB_PORT=5000
DB_NAME=bulutlake
DB_USER=bulutlake
DB_PASS=BulutLakePas24

# ── Servisler arası güvenlik ──────────────────────────────────
# Docker Compose içi tüm servisler bu anahtarı header olarak gönderir.
INTERNAL_API_KEY=change_me_before_production

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Servis URL'leri (docker-compose içi isim çözümlemesi) ─────
DB_SERVICE_URL=http://db-service:8001
QUERY_SERVICE_URL=http://query-service:8002
