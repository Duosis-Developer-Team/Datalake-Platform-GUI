  <diagram id="OcMUwRO6MqmUnGlnlPMG" name="4 - Controls">
    <mxGraphModel dx="1011" dy="510" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;fontSize=18;fontStyle=1" value="Page 4 -- Controls&lt;br&gt;&lt;font style=&#39;font-size:12px;font-weight:normal&#39;&gt;Cache stack, scheduler, auth flow, external integrations&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="700" x="350" y="10" as="geometry" />
        </mxCell>
        <mxCell id="cache" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#C2410C;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b style=&#39;font-size:14px&#39;&gt;Cache Stack (4 layers)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;L1&lt;/b&gt; GUI in-memory LRU (cache_service.py, 2048 items)&lt;br&gt;&lt;b&gt;L2&lt;/b&gt; api_client stale-while-error fallback&lt;br&gt;&lt;b&gt;L3&lt;/b&gt; Backend Redis (TTL 900s dev / 3600s prod)&lt;br&gt;&lt;b&gt;L4&lt;/b&gt; In-process TTLCache fallback (Redis down)&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#6B7280&#39; style=&#39;font-size:10px&#39;&gt;Redis logical DBs: 0=datacenter, 1=customer, 2=crm-engine&lt;/font&gt;" vertex="1">
          <mxGeometry height="260" width="600" x="60" y="90" as="geometry" />
        </mxCell>
        <mxCell id="sched" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#A16207;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b style=&#39;font-size:14px&#39;&gt;APScheduler (11 jobs)&lt;/b&gt;&lt;br&gt;&lt;br&gt;DB cache refresh -- every 15m&lt;br&gt;SLA refresh -- every 60m&lt;br&gt;Customer warm + AuraNotify -- every 15m&lt;br&gt;S3 / Backup / Phys-inv -- every 30m&lt;br&gt;Global view prefetch -- 900s (+ Interval)&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39; style=&#39;font-size:10px&#39;&gt;Risk R-02: scheduler outbound HTTP has no JWT&lt;/font&gt;" vertex="1">
          <mxGeometry height="260" width="600" x="700" y="90" as="geometry" />
        </mxCell>
        <mxCell id="af_user" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fillColor=#F1F5F9;strokeColor=#1F2937" value="User" vertex="1">
          <mxGeometry height="50" width="110" x="60" y="410" as="geometry" />
        </mxCell>
        <mxCell id="af_flask" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=11" value="Flask&lt;br&gt;auth_bp" vertex="1">
          <mxGeometry height="50" width="120" x="220" y="410" as="geometry" />
        </mxCell>
        <mxCell id="af_jwt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7C3AED;fontSize=11" value="JWT issuer&lt;br&gt;create_api_token" vertex="1">
          <mxGeometry height="50" width="130" x="380" y="410" as="geometry" />
        </mxCell>
        <mxCell id="af_be" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E6;strokeColor=#BE123C;fontSize=11" value="Backend&lt;br&gt;verify_api_user" vertex="1">
          <mxGeometry height="50" width="130" x="550" y="410" as="geometry" />
        </mxCell>
        <mxCell id="eaf1" edge="1" parent="1" source="af_user" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10" target="af_flask" value="login">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eaf2" edge="1" parent="1" source="af_flask" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10" target="af_jwt" value="g.uid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eaf3" edge="1" parent="1" source="af_jwt" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10" target="af_be" value="Bearer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="auth_label" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;spacingLeft=10" value="&lt;b&gt;Auth Flow (Flask session + HS256 JWT)&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39; color=&#39;#6B7280&#39;&gt;API_AUTH_REQUIRED=false by default; turn on for prod&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="620" x="60" y="370" as="geometry" />
        </mxCell>
        <mxCell id="ext_box" parent="1" style="text;html=1;align=left;fontSize=12;fontStyle=1;spacingLeft=10" value="&lt;b style=&#39;font-size:14px&#39;&gt;External Integrations&lt;/b&gt;" vertex="1">
          <mxGeometry height="35" width="600" x="700" y="370" as="geometry" />
        </mxCell>
        <mxCell id="p4_aura" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;fontSize=10" value="AuraNotify&lt;br&gt;:5001" vertex="1">
          <mxGeometry height="80" width="160" x="720" y="410" as="geometry" />
        </mxCell>
        <mxCell id="p4_ldap" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;fontSize=10" value="LDAP / AD" vertex="1">
          <mxGeometry height="80" width="160" x="920" y="410" as="geometry" />
        </mxCell>
        <mxCell id="p4_sla" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;fontSize=10" value="SLA API" vertex="1">
          <mxGeometry height="80" width="160" x="1120" y="410" as="geometry" />
        </mxCell>
        <mxCell id="r01" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#BE123C;dashed=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b style=&#39;color:#BE123C&#39;&gt;[!] R-01 RISK&lt;/b&gt;&lt;br&gt;&lt;br&gt;Settings PUT/DELETE only flushes GUI LRU.&lt;br&gt;Backend Redis stays stale until:&lt;br&gt;(a) next scheduler tick OR&lt;br&gt;(b) Settings -&gt; Refresh Cache button." vertex="1">
          <mxGeometry height="160" width="600" x="60" y="580" as="geometry" />
        </mxCell>
        <mxCell id="tele" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#1D4ED8;dashed=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b&gt;Telemetry overlay (see Page 6)&lt;/b&gt;&lt;br&gt;&lt;br&gt;All services emit OTLP gRPC to otel-collector.&lt;br&gt;Logs also flow via Fluent Bit -&gt; Loki in K8s.&lt;br&gt;Custom spans: dash.callback.*, auth.login/logout, cache.get/singleflight." vertex="1">
          <mxGeometry height="160" width="600" x="700" y="580" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
