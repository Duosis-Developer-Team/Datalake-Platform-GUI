  <diagram id="Kmz72MWelrKnXch8Hytf" name="6 - Observability">
    <mxGraphModel dx="1213" dy="612" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;fontSize=18;fontStyle=1" value="Page 6 -- Observability&lt;br&gt;&lt;font style=&#39;font-size:12px;font-weight:normal&#39;&gt;OTLP-based traces + logs | known gaps&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="600" x="400" y="10" as="geometry" />
        </mxCell>
        <mxCell id="svcs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b style=&#39;font-size:13px&#39;&gt;6 services (emit OTLP)&lt;/b&gt;&lt;br&gt;&lt;br&gt;datalake-webui (Dash)&lt;br&gt;datacenter-api&lt;br&gt;customer-api&lt;br&gt;query-api&lt;br&gt;admin-api&lt;br&gt;crm-engine&lt;br&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39; color=&#39;#6B7280&#39;&gt;Auto-instr: FastAPI/Flask/httpx/psycopg2/Redis&lt;/font&gt;" vertex="1">
          <mxGeometry height="320" width="260" x="60" y="100" as="geometry" />
        </mxCell>
        <mxCell id="otel" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#374151;fontSize=12;align=center" value="&lt;b&gt;OTEL Collector&lt;/b&gt;&lt;br&gt;:4317 (gRPC)&lt;br&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;Routes traces + logs&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="220" x="480" y="200" as="geometry" />
        </mxCell>
        <mxCell id="jaeger" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;align=center" value="&lt;b&gt;Trace backend&lt;/b&gt;&lt;br&gt;Jaeger / Tempo" vertex="1">
          <mxGeometry height="70" width="200" x="880" y="130" as="geometry" />
        </mxCell>
        <mxCell id="loki" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;align=center" value="&lt;b&gt;Loki&lt;/b&gt;&lt;br&gt;via Fluent Bit&lt;br&gt;monitoring ns" vertex="1">
          <mxGeometry height="70" width="200" x="880" y="230" as="geometry" />
        </mxCell>
        <mxCell id="prom" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=11;align=center" value="&lt;b&gt;Prometheus&lt;/b&gt;&lt;br&gt;scrapes /health 15s&lt;br&gt;node + k8s metrics" vertex="1">
          <mxGeometry height="70" width="200" x="880" y="330" as="geometry" />
        </mxCell>
        <mxCell id="oe1" edge="1" parent="1" source="svcs" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#15803D;strokeWidth=2;fontSize=10" target="otel" value="OTLP gRPC">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="oe2" edge="1" parent="1" source="otel" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#15803D;fontSize=10" target="jaeger" value="traces">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="oe3" edge="1" parent="1" source="otel" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1D4ED8;dashed=1;fontSize=10" target="loki" value="logs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="oe4" edge="1" parent="1" source="svcs" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#374151;dashed=1;fontSize=10;exitX=1;exitY=0.8;entryX=0;entryY=0.5" target="prom" value="scrape /health">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="gaps" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#BE123C;dashed=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b style=&#39;color:#BE123C&#39;&gt;[!] Known gaps&lt;/b&gt;&lt;br&gt;&lt;br&gt;* No application metrics (no /metrics endpoint, no RED)&lt;br&gt;* No trace_id in log format -- manual log/trace correlation&lt;br&gt;* No sampling policy (defaults to 100%)&lt;br&gt;* No PrometheusRule (SLO / alerts)&lt;br&gt;* customer-api + admin-api missing from health-scrape job&lt;br&gt;* K8s deployments missing OTEL_EXPORTER_OTLP_ENDPOINT env" vertex="1">
          <mxGeometry height="180" width="1040" x="60" y="470" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="skZxUL-KoehtG9oFFFby" name="7 - Security Boundaries">
    <mxGraphModel dx="1733" dy="874" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;fontSize=18;fontStyle=1" value="Page 7 -- Security Boundaries&lt;br&gt;&lt;font style=&#39;font-size:12px;font-weight:normal&#39;&gt;3 trust zones | what is in place | what is missing&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="600" x="400" y="10" as="geometry" />
        </mxCell>
        <mxCell id="z1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#BE123C;fontSize=12;fontStyle=1;align=left;spacingLeft=12" value="Zone 1 -- Untrusted (Internet / external)" vertex="1">
          <mxGeometry height="30" width="1320" x="40" y="80" as="geometry" />
        </mxCell>
        <mxCell id="z1_user" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#374151;fontSize=11" value="User browser" vertex="1">
          <mxGeometry height="70" width="180" x="80" y="130" as="geometry" />
        </mxCell>
        <mxCell id="z1_aura" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#374151;fontSize=11" value="AuraNotify" vertex="1">
          <mxGeometry height="70" width="180" x="320" y="130" as="geometry" />
        </mxCell>
        <mxCell id="z1_ldap" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#374151;fontSize=11" value="LDAP / AD" vertex="1">
          <mxGeometry height="70" width="180" x="560" y="130" as="geometry" />
        </mxCell>
        <mxCell id="z1_sla" parent="1" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#374151;fontSize=11" value="SLA API" vertex="1">
          <mxGeometry height="70" width="180" x="800" y="130" as="geometry" />
        </mxCell>
        <mxCell id="z2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=12;fontStyle=1;align=left;spacingLeft=12" value="Zone 2 -- Edge (K8s ingress + Flask middleware)" vertex="1">
          <mxGeometry height="30" width="1320" x="40" y="230" as="geometry" />
        </mxCell>
        <mxCell id="z2_ingress" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#B45309;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" value="&lt;b&gt;K8s ingress&lt;/b&gt; (bulutistan.local)&lt;br&gt;Routes /api/v1/* + /&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] admin-api routes missing&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] no rate-limit annotation&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="560" x="80" y="280" as="geometry" />
        </mxCell>
        <mxCell id="z2_flask" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#B45309;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" value="&lt;b&gt;Flask middleware&lt;/b&gt;&lt;br&gt;Cache-Control set on /assets/*, /_dash/*&lt;br&gt;Session cookie signed by SECRET_KEY&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] No CSP / HSTS / X-Frame-Options&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] Secure / HttpOnly flags not set&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] No CSRF token on /auth/login&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="680" x="680" y="280" as="geometry" />
        </mxCell>
        <mxCell id="z3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;fontSize=12;fontStyle=1;align=left;spacingLeft=12" value="Zone 3 -- Trusted (cluster internal)" vertex="1">
          <mxGeometry height="30" width="1320" x="40" y="420" as="geometry" />
        </mxCell>
        <mxCell id="z3_jwt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#15803D;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" value="&lt;b&gt;JWT propagation (purple path)&lt;/b&gt;&lt;br&gt;Flask request -&gt; g.auth_user_id&lt;br&gt;api_client._auth_headers() injects HS256 Bearer&lt;br&gt;Backend verify_api_user dependency&lt;br&gt;&lt;font color=&#39;#15803D&#39;&gt;[OK] In place (default off in dev)&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] API_AUTH_REQUIRED=false default; prod must turn on&lt;/font&gt;" vertex="1">
          <mxGeometry height="150" width="620" x="80" y="470" as="geometry" />
        </mxCell>
        <mxCell id="z3_cors" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#15803D;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" value="&lt;b&gt;Backend CORS&lt;/b&gt;&lt;br&gt;All 5 services: allow_origins=[&#39;*&#39;]&lt;br&gt;allow_credentials=True&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] Too permissive&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] No rate-limit middleware&lt;/font&gt;" vertex="1">
          <mxGeometry height="150" width="640" x="720" y="470" as="geometry" />
        </mxCell>
        <mxCell id="z3_secrets" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#15803D;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" value="&lt;b&gt;Secrets (k8s Secret reference)&lt;/b&gt;&lt;br&gt;SECRET_KEY, API_JWT_SECRET, FERNET_KEY, DB passwords&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] Defaults are change_me_* in code&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] No vault / sealed-secrets integration&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="620" x="80" y="640" as="geometry" />
        </mxCell>
        <mxCell id="z3_fernet" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#15803D;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" value="&lt;b&gt;Fernet (LDAP password encryption)&lt;/b&gt;&lt;br&gt;SHA256(SECRET_KEY) -&gt; base64-urlsafe (non-standard)&lt;br&gt;&lt;font color=&#39;#BE123C&#39;&gt;[X] Rotating SECRET_KEY breaks LDAP decryption&lt;/font&gt;" vertex="1">
          <mxGeometry height="130" width="640" x="720" y="640" as="geometry" />
        </mxCell>
        <mxCell id="risks" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#BE123C;dashed=1;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" value="&lt;b style=&#39;color:#BE123C&#39;&gt;Top security gaps to close before prod&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. Replace change_me_* defaults; rotate SECRET_KEY + FERNET_KEY + DB passwords&lt;br&gt;2. Turn on API_AUTH_REQUIRED=true on all 5 backends&lt;br&gt;3. CORS allow_origins whitelist (not &#39;*&#39;)&lt;br&gt;4. Add rate-limit (slowapi or ingress annotation)&lt;br&gt;5. Add CSP + HSTS + X-Frame-Options headers in Flask after_request&lt;br&gt;6. Session cookie Secure=True + SameSite=Strict + HttpOnly&lt;br&gt;7. CSRF token on Flask /auth/login form" vertex="1">
